{
  "name": "ripple",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.22.2"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "pnpm --filter @ripple/web dev",
    "dev:backend": "pnpm --filter @ripple/convex dev",
    "dev:partykit": "pnpm --filter @ripple/partykit dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @ripple/web test:watch",
    "test:backend": "pnpm --filter @ripple/convex test",
    "test:frontend": "pnpm --filter @ripple/web test",
    "deploy:convex": "pnpm --filter @ripple/convex deploy",
    "deploy:frontend": "pnpm --filter @ripple/web deploy",
    "deploy": "pnpm --filter @ripple/web build && pnpm --filter @ripple/convex deploy && pnpm --filter @ripple/web deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "dotenv": "17.2.4",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "turbo": "2.5.8",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1"
  }
}
